{
	"version": 1,
	"disable_existing_loggers": false,
	"formatters": {
		"formatter_console": {
			"format": "[%(levelname)s]_[%(name)s]: %(message)s"
		}
	},
	"handlers": {
		"handler_console": {
			"level": "DEBUG",
			"formatter": "formatter_console",
			"class": "logging.StreamHandler",
			"stream": "ext://sys.stdout"
		}
	},
	"loggers": {
		"": {
			"handlers": ["handler_console"],
			"level": "INFO"
		},
      	"thephish_app": {
			"handlers": ["handler_console"],
			"level": "INFO",
			"propagate": false
		},
		"geventwebsocket.handler": {
			"handlers": ["handler_console"],
			"level": "WARN",
			"propagate": false
		}
	}
}
